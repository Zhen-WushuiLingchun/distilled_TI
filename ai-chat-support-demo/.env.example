# Copy to ai-chat-support-demo/.env if you run the standalone static demo.
# This API base includes /api because server.py calls {DISTILLED_TI_API_BASE}/context/analyze.
DISTILLED_TI_API_BASE=http://127.0.0.1:8000/api

# Must match backend/.env CONTEXT_ANALYSIS_API_KEY unless backend uses
# CONTEXT_ANALYSIS_ALLOW_UNAUTH_LOCAL=true for local-only smoke tests.
DISTILLED_TI_CONTEXT_API_KEY=your_context_api_key

# Optional OpenAI-compatible chat model for the assistant demo.
# If unset, the demo uses a local deterministic fallback assistant.
DEMO_CHAT_BASE_URL=
DEMO_CHAT_API_KEY=
DEMO_CHAT_MODEL=
DEMO_CHAT_TIMEOUT_SECONDS=30
