# Optional defaults. The UI can edit and save these values locally.
DSTI_SITE_URL=https://dsti.hydrogenoxide18.com
DSTI_API_BASE_URL=https://dsti.hydrogenoxide18.com/api
SENREN_COMPANION_PORT=17877

# Optional OCR capture mode. Clipboard mode does not need these.
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
SENREN_OCR_LANG=jpn+chi_sim+eng
# Optional screen region: x,y,width,height. Leave empty to OCR the whole screen.
SENREN_OCR_REGION=
