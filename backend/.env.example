# Full local integration profile.
# Copy to backend/.env, then replace all "your_*" placeholders with local secrets.
# Never commit backend/.env. If you only need a no-key smoke run, copy .env.minimal.example instead.

# -----------------------------------------------------------------------------
# 0. Server, CORS, storage
# -----------------------------------------------------------------------------
APP_NAME=Distilled TI Backend
API_PREFIX=/api
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3001,http://localhost:3001,http://127.0.0.1:3100,http://localhost:3100,http://127.0.0.1:3101,http://localhost:3101
LOCAL_DB_PATH=distilled_ti_local.db

SESSION_TTL_HOURS=1
REGISTERED_SESSION_TTL_DAYS=3650
MIN_QUESTIONS_FOR_REPORT=20
MAX_QUESTIONS_PER_SESSION=10000

# -----------------------------------------------------------------------------
# 1. Measurement/scoring defaults
# These usually do not need to change during integration.
# -----------------------------------------------------------------------------
DEFAULT_SIGMA=1.5
MIN_SIGMA=0.35
SCORE_CLIP=3.0
ETA0=0.35
ETA_DECAY=20.0
SIGMA_SHRINK=0.08
SIGMA_DRIFT=0.01
SUBDIMENSION_UNLOCK_THRESHOLD=4
MODULE_ACTIVATION_THRESHOLD=3

CLUSTER_REFRESH_MIN_SAMPLES=12
CLUSTER_COUNT=4
EXACT_REPEAT_COOLDOWN=36
SEMANTIC_REPEAT_WINDOW=24
SEMANTIC_REPEAT_THRESHOLD=0.58
SCENARIO_REPEAT_WINDOW=6
RANKED_CANDIDATE_WINDOW=40

AI_SUMMARY_MAX_TOKENS=900
REWRITE_CANDIDATE_COUNT=4
REWRITE_TARGET_LENGTH=48
AI_REWRITE_TARGET_RATIO=0.35
AI_REWRITE_PRIORITY_BONUS=0.9
AI_REWRITE_EXPAND_AFTER_QUESTION=3
AI_PROBE_TARGET_RATIO=0.22
AI_PROBE_FIRST_QUESTION=4
AI_PROBE_MAX_COUNT=8
AI_CONTRAST_TARGET_RATIO=0.4

# -----------------------------------------------------------------------------
# 2. LLM provider acceptance defaults
# Runtime LLM config is persisted through Admin /api/ai/config.
# These variables are used by backend/scripts/ai_acceptance.py; run with --save
# after a successful test to write the provider into local SQLite.
# -----------------------------------------------------------------------------
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=your_deepseek_key
AI_MODEL=deepseek-v4-pro

# -----------------------------------------------------------------------------
# 3. Embedding, reranker, and Qdrant
# Recommended local provider: SiliconFlow BAAI/bge-m3 + BAAI/bge-reranker-v2-m3.
# Windows dev can use QDRANT_LOCAL_PATH without Docker. For Docker/remote Qdrant,
# leave QDRANT_LOCAL_PATH empty and set QDRANT_URL.
# -----------------------------------------------------------------------------
VECTOR_ENABLED=true

EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=your_siliconflow_key
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_TIMEOUT_SECONDS=12

RERANKER_BASE_URL=https://api.siliconflow.cn/v1
RERANKER_API_KEY=your_siliconflow_key
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TIMEOUT_SECONDS=12

QDRANT_LOCAL_PATH=.qdrant-local
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_ITEM_VECTORS=item_vectors
QDRANT_COLLECTION_SESSION_VECTORS=session_vectors

VECTOR_SEARCH_TOP_K=5
VECTOR_SEARCH_SCORE_THRESHOLD=0.58
SESSION_VECTOR_MILESTONES=5,10,20,40
SESSION_VECTOR_TOP_K=5
GALGAME_TURN_VECTOR_TOP_K=5
GALGAME_FREE_TEXT_INFERENCE_MIN_CONFIDENCE=0.42
GALGAME_MIN_TURNS_FOR_REPORT=20
# Story mode uses the generated story plan length as the natural ending.
# This value is only a safety floor and will not truncate a longer story plan.
GALGAME_MAX_TURNS_PER_SESSION=80

# -----------------------------------------------------------------------------
# 4. Story/Galgame live scene generation
# Story scene calls reuse the saved LLM provider. The DeepSeek-specific thinking
# controls below are safe to keep for providers that ignore unknown fields because
# the AI service retries without them if necessary.
# -----------------------------------------------------------------------------
GALGAME_AI_SCENE_ENABLED=true
GALGAME_AI_SCENE_TIMEOUT_SECONDS=90
GALGAME_AI_SCENE_MAX_TOKENS=4096
GALGAME_AI_SCENE_THINKING_TYPE=disabled
GALGAME_AI_SCENE_REASONING_EFFORT=
GALGAME_AI_SCENE_OUTPUT_EFFORT=

# -----------------------------------------------------------------------------
# 5. Story/Galgame image and audio assets
# Default integration mode is GPU-free cloud image generation through Volcengine
# Ark Seedream. To use local SD WebUI instead, change GALGAME_ASSET_BACKEND to
# sdwebui and GALGAME_ASSET_BASE_URL to http://127.0.0.1:7860.
# -----------------------------------------------------------------------------
GALGAME_ASSET_GENERATION_ENABLED=true
GALGAME_ASSET_BACKEND=volcengine_seedream
GALGAME_ASSET_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
GALGAME_ASSET_API_KEY=your_volcengine_ark_api_key
GALGAME_ASSET_MODEL=doubao-seedream-5-0-260128
GALGAME_ASSET_RESPONSE_FORMAT=url
GALGAME_ASSET_QUALITY=
GALGAME_ASSET_WATERMARK=false
GALGAME_ASSET_SIZE_BACKGROUND=2K
GALGAME_ASSET_SIZE_CHARACTER=2K
GALGAME_ASSET_SEQUENTIAL_IMAGE_GENERATION=disabled
GALGAME_ASSET_STREAM=false

GALGAME_ASSET_PUBLIC_DIR=frontend/public/generated/galgame
GALGAME_ASSET_PUBLIC_URL_PREFIX=/generated/galgame
GALGAME_ASSET_TIMEOUT_SECONDS=180
GALGAME_ASSET_GENERATE_BACKGROUNDS=true
GALGAME_ASSET_GENERATE_CHARACTERS=true
GALGAME_ASSET_CLEANUP_ENABLED=true
GALGAME_ASSET_CACHE_MAX_FILES=300
GALGAME_ASSET_CACHE_MAX_AGE_DAYS=14
GALGAME_AUDIO_ASSET_ENABLED=false

# Optional local SD WebUI override:
# GALGAME_ASSET_BACKEND=sdwebui
# GALGAME_ASSET_BASE_URL=http://127.0.0.1:7860
# GALGAME_ASSET_MODEL=
# GALGAME_ASSET_API_KEY=

# -----------------------------------------------------------------------------
# 6. Invite-only identity, login codes, email, and hidden recommendations
# Production/public demos should not expose a reusable bootstrap code. Create
# one-time invites in Admin instead. USER_INVITE_MAX_USES=1 makes user-generated
# invites single-use.
# -----------------------------------------------------------------------------
INVITE_BOOTSTRAP_CODE=
INVITE_BOOTSTRAP_MAX_USES=1
INVITE_DEFAULT_MAX_USES=1
USER_INVITE_MAX_USES=1
RELATIONSHIP_RECOMMENDATIONS_ENABLED=false

AUTH_LOGIN_CODE_TTL_MINUTES=10
AUTH_LOGIN_CODE_RETURN_IN_RESPONSE=false
EMAIL_PROVIDER=resend
EMAIL_FROM="Distilled TI <no-reply@example.com>"
EMAIL_TIMEOUT_SECONDS=10
RESEND_API_KEY=your_resend_key
RESEND_BASE_URL=https://api.resend.com

# -----------------------------------------------------------------------------
# 7. Universal context support-signal API
# Set CONTEXT_ANALYSIS_API_KEY for any non-local or shared demo. The key is a
# server-side secret you choose yourself; clients send it as X-Context-API-Key.
# -----------------------------------------------------------------------------
CONTEXT_ANALYSIS_API_KEY=your_context_api_key
CONTEXT_ANALYSIS_ALLOW_UNAUTH_LOCAL=false
CONTEXT_ANALYSIS_RECENT_MESSAGE_LIMIT=30
CONTEXT_ANALYSIS_STORE_RAW_MESSAGES=false

# -----------------------------------------------------------------------------
# 8. Senren/local game monitor
# SENREN_LOCAL_GAME_ALLOW_REMOTE should remain false unless the service is behind
# a trusted internal network and the path access model has been reviewed.
# -----------------------------------------------------------------------------
SENREN_MONITOR_ENABLED=true
SENREN_LOCAL_GAME_ALLOW_REMOTE=false
SENREN_CHARACTER_ASSET_DIR=.local/senren-character-assets
SENREN_MIN_CHOICES_FOR_REPORT=8
